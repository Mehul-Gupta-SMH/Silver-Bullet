# SilverBullet — environment variable template
# Copy this file to .env and fill in your values before running docker-compose.

# Path to the trained model checkpoint (inside the container)
MODEL_PATH=best_model.pth

# Comma-separated list of additional allowed CORS origins
# http://localhost:5173 is always allowed for local frontend dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# HuggingFace token — required for gated models (Qwen3-Embedding etc.)
SB_HF_TOKEN=

# OpenAI token — required for GPT-4o-mini coref resolver
SB_OPENAI_TOKEN=

# Internal API key (optional, for request-level authentication)
SB_API_KEY=
