# SilverBullet — environment variable template
# Copy this file to .env and fill in your values before running docker-compose.

# General fallback model checkpoint (used when no mode-specific checkpoint exists)
MODEL_PATH=best_model.pth

# Per-mode model checkpoints — created by: python train.py --mode <mode>
# If unset or the file is missing, MODEL_PATH above is used as a fallback.
MODEL_PATH_MODEL_VS_MODEL=models/model-vs-model.pth
MODEL_PATH_REFERENCE_VS_GENERATED=models/reference-vs-generated.pth
MODEL_PATH_CONTEXT_VS_GENERATED=models/context-vs-generated.pth

# Comma-separated list of additional allowed CORS origins
# http://localhost:5173 is always allowed for local frontend dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# HuggingFace token — required for gated models (Qwen3-Embedding etc.)
SB_HF_TOKEN=

# OpenAI token — required for GPT-4o-mini coref resolver
SB_OPENAI_TOKEN=

# Internal API key (optional, for request-level authentication)
SB_API_KEY=
